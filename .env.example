# Clerk Authentication Keys (Required for ISO 27001 Access Control)
# Get these from your Clerk Dashboard (https://dashboard.clerk.com) -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# The URL of your Next.js application (used by Clerk for redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# The root domain of your platform (used by Next.js middleware for tenant routing)
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# LuminaCast White-labeling Overrides (Optional)
# NEXT_PUBLIC_PLATFORM_NAME="Custom Academy"
# NEXT_PUBLIC_COMPANY_NAME="Custom LLC"

# The .NET 10 gRPC Backend URL
GRPC_BACKEND_URL=localhost:5000
